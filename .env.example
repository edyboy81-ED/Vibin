# PostgreSQL connection string (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/vibin?sslmode=require"

# Password to log in to the app
APP_PASSWORD="change-me"

# Random 32+ char secret for signing session cookies
SESSION_SECRET="replace-with-a-long-random-string"

# Gmail account used to send reconciliation emails
GMAIL_USER="you@gmail.com"

# Gmail App Password (not your account password — generate at myaccount.google.com/apppasswords)
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
